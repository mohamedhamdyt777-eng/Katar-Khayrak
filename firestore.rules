rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    // Any authenticated user can read their own document.
    // Only that user can write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Campaigns ─────────────────────────────────────────────────────────────
    // Any authenticated user can read campaigns.
    // Only authenticated users can create campaigns.
    // Only the organization that created the campaign can update/delete it.
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.organizationId == request.auth.uid;
    }
  }
}
